#!/usr/bin/env python3
import json
import os
import shlex
import shutil
import subprocess
import sys
import time
from pathlib import Path


APP_NAME = "tx"
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / APP_NAME
CONFIG_FILE = CONFIG_DIR / "commands.json"
RESERVED_ALIASES = {"add", "list", "help", "version", "terminal"}
SUPPORTED_TERMINALS = {"auto", "ghostty", "iterm2"}
VERSION = "0.1.6"


HELP = f"""tx {VERSION} - launch registered CLIs in a 2x2 terminal layout

Usage:
  tx [--terminal auto|ghostty|iterm2] <name-or-alias>
  tx add <name>
  tx add <name> -<alias> [-- <command ...>]
  tx add <name> --alias <alias> [-- <command ...>]
  tx list
  tx terminal
  tx terminal auto|ghostty|iterm2
  tx help
  tx version
  tx --dry-run <name-or-alias>

Examples:
  tx add claude
  tx add claude -cc
  tx terminal ghostty
  tx add codex -cx
  tx add codex-full -cf -- codex --dangerously-bypass-approvals-and-sandbox
  tx claude
  tx --terminal iterm2 cc
  tx cc

Registry:
  {CONFIG_FILE}
"""


def main(argv):
    if not argv or argv[0] in {"help", "-h", "--help"}:
        print(HELP.rstrip())
        return

    terminal_override, argv = parse_global_options(argv)
    if not argv:
        print(HELP.rstrip())
        return

    cmd, *args = argv
    if cmd == "add":
        add_command(args)
    elif cmd == "list":
        list_commands()
    elif cmd == "terminal":
        terminal_command(args)
    elif cmd == "version":
        print(VERSION)
    elif cmd == "--dry-run":
        if not args:
            die("--dry-run requires a registered name or alias")
        run_alias(normalize_alias(args[0]), terminal_override, dry_run=True)
    else:
        run_alias(normalize_alias(cmd), terminal_override)


def parse_global_options(argv):
    terminal = None
    remaining = []
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--terminal":
            if i + 1 >= len(argv):
                die("--terminal requires one of: auto, ghostty, iterm2")
            terminal = normalize_terminal(argv[i + 1])
            i += 2
            continue
        if arg.startswith("--terminal="):
            terminal = normalize_terminal(arg.split("=", 1)[1])
            i += 1
            continue
        remaining.extend(argv[i:])
        break
    return terminal, remaining


def add_command(args):
    name, aliases, command = parse_add_args(args)
    data = load_registry()
    for alias in aliases:
        data["commands"][alias] = {"name": name, "command": command}
    save_registry(data)
    for alias in aliases:
        print(f"registered: tx {alias} -> {command}")


def list_commands():
    data = load_registry()
    commands = data["commands"]
    if not commands:
        print("No commands registered yet.")
        print("Try: tx add claude")
        return

    print(f"Terminal: {configured_terminal(data)}")
    print()
    rows = [("ALIAS", "NAME", "COMMAND")]
    for alias, item in sorted(commands.items()):
        rows.append((alias, str(item.get("name", "")), str(item.get("command", ""))))

    widths = [max(len(row[i]) for row in rows) for i in range(3)]
    for idx, row in enumerate(rows):
        print("  ".join(row[i].ljust(widths[i]) for i in range(3)).rstrip())
        if idx == 0:
            print("  ".join("-" * width for width in widths))


def parse_add_args(args):
    if not args:
        die("missing command name\n\n" + HELP)

    name = args[0]
    aliases = [normalize_alias(name)]
    command = None
    i = 1

    while i < len(args):
        arg = args[i]
        if arg == "--":
            command = args[i + 1 :]
            break
        if arg in ("--alias", "-a"):
            if i + 1 >= len(args):
                die(f"{arg} requires a value")
            aliases.append(normalize_alias(args[i + 1]))
            i += 2
            continue
        if arg.startswith("-") and len(arg) > 1:
            aliases.append(normalize_alias(arg[1:]))
            i += 1
            continue
        die(f"unexpected argument for add: {arg}")

    if command is None or len(command) == 0:
        command = [name]

    return name, unique_aliases(aliases), shlex.join(command)


def unique_aliases(aliases):
    seen = set()
    result = []
    for alias in aliases:
        if alias not in seen:
            seen.add(alias)
            result.append(alias)
    return result


def normalize_alias(alias):
    alias = alias.strip()
    if alias.startswith("-"):
        alias = alias.lstrip("-")
    if not alias:
        die("alias cannot be empty")
    if alias in RESERVED_ALIASES:
        die(f"alias '{alias}' is reserved")
    if any(ch.isspace() for ch in alias):
        die("alias cannot contain whitespace")
    return alias


def load_registry():
    if not CONFIG_FILE.exists():
        return default_registry()
    try:
        with CONFIG_FILE.open("r", encoding="utf-8") as f:
            data = json.load(f)
    except (OSError, json.JSONDecodeError) as exc:
        die(f"failed to read {CONFIG_FILE}: {exc}")
    if not isinstance(data, dict) or not isinstance(data.get("commands"), dict):
        die(f"invalid registry format in {CONFIG_FILE}")
    if not isinstance(data.get("settings"), dict):
        data["settings"] = {}
    return data


def default_registry():
    return {"commands": {}, "settings": {}}


def save_registry(data):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    tmp = CONFIG_FILE.with_suffix(".json.tmp")
    with tmp.open("w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False, sort_keys=True)
        f.write("\n")
    tmp.replace(CONFIG_FILE)


def terminal_command(args):
    data = load_registry()
    if not args:
        print(configured_terminal(data))
        return
    if len(args) != 1:
        die("usage: tx terminal auto|ghostty|iterm2")
    terminal = normalize_terminal(args[0])
    data.setdefault("settings", {})["terminal"] = terminal
    save_registry(data)
    print(f"terminal: {terminal}")


def configured_terminal(data):
    return normalize_terminal(data.get("settings", {}).get("terminal", "auto"))


def normalize_terminal(value):
    value = str(value).strip().lower()
    if value not in SUPPORTED_TERMINALS:
        die(f"unsupported terminal '{value}'. Use one of: auto, ghostty, iterm2")
    return value


def resolve_terminal(selection):
    selection = normalize_terminal(selection or os.environ.get("TX_TERMINAL", "auto"))
    if selection != "auto":
        return selection

    term_program = os.environ.get("TERM_PROGRAM", "").lower()
    if "ghostty" in term_program:
        return "ghostty"
    if "iterm" in term_program:
        return "iterm2"
    if Path("/Applications/Ghostty.app").exists():
        return "ghostty"
    return "iterm2"


def launch_four(command, cwd, alias, terminal):
    if terminal == "ghostty":
        launch_ghostty(command, cwd)
    elif terminal == "iterm2":
        if shutil.which("tmux") is None:
            die("tmux is required. Install it first, then run tx again.")
        tmux_command = build_tmux_command(command, cwd, alias)
        launch_iterm2(tmux_command)
    else:
        die(f"unsupported terminal '{terminal}'")


def launch_ghostty(command, cwd):
    if not Path("/Applications/Ghostty.app").exists():
        die("Ghostty.app was not found in /Applications")
    pane_command = build_pane_command(command, cwd)
    use_current_terminal = "ghostty" in os.environ.get("TERM_PROGRAM", "").lower()
    try:
        run_ghostty_split_script(pane_command, cwd, use_current_terminal)
    except FileNotFoundError:
        die("open is not available; Ghostty launch currently supports macOS")
    except subprocess.CalledProcessError as exc:
        die(f"failed to launch Ghostty (exit {exc.returncode})")
    if use_current_terminal:
        os.execv("/bin/zsh", ["/bin/zsh", "-lc", pane_command])


def run_ghostty_split_script(pane_command, cwd, use_current_terminal):
    if use_current_terminal:
        script = f"""
on run_command(commandText, targetTerminal)
  tell application "Ghostty"
    input text commandText to targetTerminal
    send key "enter" to targetTerminal
  end tell
end run_command

tell application "Ghostty"
  activate

  set cfg to new surface configuration
  set initial working directory of cfg to {applescript_string(cwd)}

  set targetWindow to front window
  set targetTab to selected tab of targetWindow
  set paneOne to focused terminal of targetTab

  set paneTwo to split paneOne direction right with configuration cfg
  set paneThree to split paneOne direction down with configuration cfg
  set paneFour to split paneTwo direction down with configuration cfg

  my run_command({applescript_string(pane_command)}, paneTwo)
  my run_command({applescript_string(pane_command)}, paneThree)
  my run_command({applescript_string(pane_command)}, paneFour)

  focus paneOne
end tell
"""
    else:
        script = f"""
on run_command(commandText, targetTerminal)
  tell application "Ghostty"
    input text commandText to targetTerminal
    send key "enter" to targetTerminal
  end tell
end run_command

tell application "Ghostty"
  activate

  set cfg to new surface configuration
  set initial working directory of cfg to {applescript_string(cwd)}

  set targetWindow to new window with configuration cfg
  set paneOne to terminal 1 of selected tab of targetWindow
  set paneTwo to split paneOne direction right with configuration cfg
  set paneThree to split paneOne direction down with configuration cfg
  set paneFour to split paneTwo direction down with configuration cfg

  my run_command({applescript_string(pane_command)}, paneOne)
  my run_command({applescript_string(pane_command)}, paneTwo)
  my run_command({applescript_string(pane_command)}, paneThree)
  my run_command({applescript_string(pane_command)}, paneFour)

  focus paneOne
end tell
"""
    try:
        subprocess.run(["osascript", "-e", script], check=True)
    except FileNotFoundError:
        die("osascript is not available; Ghostty split launch currently supports macOS")
    except subprocess.CalledProcessError as exc:
        die(
            "failed to control Ghostty via AppleScript. "
            "Ghostty 1.3+ and macOS Automation permission are required. "
            f"(exit {exc.returncode})"
        )


def launch_iterm2(tmux_command):
    script = f"""
tell application "iTerm2"
  activate
  if (count of windows) = 0 then
    create window with default profile
  end if

  set targetWindow to current window
  tell targetWindow
    set targetTab to current tab
    tell targetTab
      tell current session
        write text {applescript_string(tmux_command)}
      end tell
    end tell
  end tell
end tell
"""
    try:
        subprocess.run(["osascript", "-e", script], check=True)
    except FileNotFoundError:
        die("osascript is not available; iTerm2 launch currently supports macOS")
    except subprocess.CalledProcessError as exc:
        die(f"failed to control iTerm2 via AppleScript (exit {exc.returncode})")


def run_alias(alias, terminal_override=None, dry_run=False):
    data = load_registry()
    item = data["commands"].get(alias)
    if item is None:
        die(f"unknown command alias '{alias}'. Run 'tx list' to see registered commands.")
    command = item.get("command")
    if not isinstance(command, str) or not command:
        die(f"invalid command registered for alias '{alias}'")
    cwd = os.getcwd()
    terminal = resolve_terminal(terminal_override or configured_terminal(data))
    if dry_run:
        print(f"terminal: {terminal}")
        if terminal == "ghostty":
            print(build_pane_command(command, cwd))
        else:
            print(build_tmux_command(command, cwd, alias))
        return
    launch_four(command, cwd, alias, terminal)


def build_pane_command(command, cwd):
    return f"cd {shlex.quote(cwd)} && {command}"


def build_tmux_command(command, cwd, alias):
    session = f"tx-{safe_session_part(alias)}-{int(time.time())}-{os.getpid()}"
    target = f"{session}:0"
    commands = [
        ["tmux", "new-session", "-d", "-s", session, "-c", cwd, command],
        ["tmux", "split-window", "-h", "-t", target, "-c", cwd, command],
        ["tmux", "select-pane", "-t", f"{target}.0"],
        ["tmux", "split-window", "-v", "-t", f"{target}.0", "-c", cwd, command],
        ["tmux", "select-pane", "-t", f"{target}.1"],
        ["tmux", "split-window", "-v", "-t", f"{target}.1", "-c", cwd, command],
        ["tmux", "select-layout", "-t", target, "tiled"],
        ["tmux", "attach-session", "-t", session],
    ]
    return " && ".join(shlex.join(item) for item in commands)


def safe_session_part(value):
    safe = []
    for ch in value:
        if ch.isalnum() or ch in {"_", "-"}:
            safe.append(ch)
        else:
            safe.append("-")
    return "".join(safe) or "session"


def applescript_string(value):
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


def die(message, code=1):
    print(f"tx: {message}", file=sys.stderr)
    sys.exit(code)


if __name__ == "__main__":
    main(sys.argv[1:])
